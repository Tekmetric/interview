---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import AsteroidList from "../components/AsteroidList";
import { SITE_TITLE } from "../consts";

// Disable prerendering to ensure server-side rendering
export const prerender = false;

// Read page parameter from URL
const page = parseInt(Astro.url.searchParams.get("page") || "0", 10);

// Fetch data server-side
const runtime = Astro.locals.runtime as any;
const apiKey = runtime?.env?.NASA_API_KEY;

const response = await fetch(
  `https://api.nasa.gov/neo/rest/v1/neo/browse?page=${page}&api_key=${apiKey}`
);

const data = await response.json();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Browse All Asteroids - ${SITE_TITLE}`}
      description="Browse the complete catalog of Near Earth Objects tracked by NASA"
    />
  </head>
  <body>
    <Header />
    <main>
      <AsteroidList page={page} data={data} client:load />
    </main>
  </body>
</html>

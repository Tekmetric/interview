          }
        }
      },
      "targets": [
        {
          "expr": "auth_login_total{outcome=\"failure\"}",
          "legendFormat": "failures"
        }
      ]
    },
    {
      "title": "\ud83c\udf10 HTTP Metrics",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "collapsed": true,
      "panels": [
        {
          "title": "HTTP Request Rate by Endpoint",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 5
          },
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "reqps",
              "custom": {
                "fillOpacity": 10
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "right"
            }
          },
          "targets": [
            {
              "expr": "sum by (method, uri) (rate(http_server_requests_milliseconds_count[5m]))",
              "legendFormat": "{{method}} {{uri}}"
            }
          ]
        },
        {
          "title": "HTTP Avg Response Time by Endpoint",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 5
          },
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "ms",
              "custom": {
                "fillOpacity": 10
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "right"
            }
          },
          "targets": [
            {
              "expr": "sum by (method, uri) (rate(http_server_requests_milliseconds_sum[5m])) / sum by (method, uri) (rate(http_server_requests_milliseconds_count[5m]))",
              "legendFormat": "{{method}} {{uri}}"
            }
          ]
        },
        {
          "title": "HTTP Error Rate by Endpoint",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 13
          },
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "reqps",
              "custom": {
                "fillOpacity": 10
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": ".*401.*"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "orange"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": ".*403.*"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "yellow"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": ".*404.*"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "purple"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": ".*409.*"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "blue"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": ".*5.."
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "red"
                    }
                  }
                ]
              }
            ]
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "right"
            }
          },
          "targets": [
            {
              "expr": "sum by (method, uri, status) (rate(http_server_requests_milliseconds_count{status=~\"4..|5..\"}[5m]))",
              "legendFormat": "{{status}} {{method}} {{uri}}"
            }
          ]
        },
        {
          "title": "HTTP Status Codes",
          "type": "timeseries",
          "gridPos": {
            "h": 8,

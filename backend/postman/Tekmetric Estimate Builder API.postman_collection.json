      "key": "standaloneWorkOrderId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Estimates",
      "item": [
        {
          "name": "POST /api/estimates",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"vehicleId\": \"{{vehicleId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/estimates"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('creates estimate', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set('estimateId', response.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/estimates/{id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/estimates/{{seededEstimateId}}"
          }
        },
        {
          "name": "GET /api/estimates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/estimates?customerId={{customerId}}&status=PENDING&page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "estimates"
              ],
              "query": [
                {
                  "key": "customerId",
                  "value": "{{customerId}}"
                },
                {
                  "key": "status",
                  "value": "PENDING"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "PUT /api/estimates/{id}",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\"\n}"
            },
            "url": "{{baseUrl}}/api/estimates/{{estimateId}}"
          }
        },
        {
          "name": "POST /api/estimates/{estimateId}/work-orders",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleId\": \"{{vehicleId}}\",\n  \"status\": \"PENDING\",\n  \"summary\": \"Replace front brake pads\",\n  \"notes\": \"Pads are worn below recommended thickness.\",\n  \"laborRate\": 100.00,\n  \"laborTime\": 2.00,\n  \"partsNeeded\": [\n    { \"partId\": \"{{brakePadPartId}}\", \"quantity\": 1 },\n    { \"partId\": \"{{brakePadPartId}}\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/estimates/{{estimateId}}/work-orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('creates and associates work order', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "if (response.workOrders && response.workOrders.length > 0) {",
                  "    pm.collectionVariables.set('estimateWorkOrderId', response.workOrders[response.workOrders.length - 1].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/estimates/{estimateId}/work-orders/{workOrderId}",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/estimates/{{estimateId}}/work-orders/{{approvedSeededWorkOrderId}}"
          }
        },
        {
          "name": "DELETE /api/estimates/{id}",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/estimates/{{estimateId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('deletes estimate', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Work Orders",
      "item": [
        {
          "name": "POST /api/work-orders",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleId\": \"{{vehicleId}}\",\n  \"status\": \"PENDING\",\n  \"summary\": \"Tune ignition and belt system\",\n  \"notes\": \"Demo standalone work order.\",\n  \"laborRate\": 120.00,\n  \"laborTime\": 1.00,\n  \"partsNeeded\": [\n    { \"partId\": \"{{sparkPlugPartId}}\", \"quantity\": 4 },\n    { \"partId\": \"{{beltPartId}}\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/work-orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('creates standalone work order', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.collectionVariables.set('standaloneWorkOrderId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/work-orders/{id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/work-orders/{{seededWorkOrderId}}"
          }
        },
        {
          "name": "GET /api/work-orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/work-orders?status=ACCEPTED&page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "work-orders"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "ACCEPTED"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "PUT /api/work-orders/{id}",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\",\n  \"summary\": \"Replace ignition components\",\n  \"notes\": \"Updated after technician inspection.\",\n  \"laborRate\": 120.00,\n  \"laborTime\": 1.00,\n  \"partsNeeded\": [\n    { \"partId\": \"{{sparkPlugPartId}}\", \"quantity\": 4 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/work-orders/{{standaloneWorkOrderId}}"
          }
        },
        {
          "name": "DELETE /api/work-orders/{id}",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/work-orders/{{standaloneWorkOrderId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('deletes work order', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]

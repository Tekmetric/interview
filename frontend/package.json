{
  "name": "rick-and-morty-wiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:styles": "stylelint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"{src,e2e}/**/*.{ts,tsx,json}\" \"*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"{src,e2e}/**/*.{ts,tsx,json}\" \"*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@tanstack/react-virtual": "^3.14.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-intl": "^10.1.16",
    "react-redux": "^9.3.0",
    "react-router": "^8.2.0",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "postcss-styled-syntax": "^0.7.2",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}

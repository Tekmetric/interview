{
  "realm": "tekmetric",
  "displayName": "Tekmetric Realm",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 30,
  "defaultRoles": [
    "default-roles-tekmetric"
  ],
  "accessTokenLifespan": 6000,
  "ssoSessionIdleTimeout": 7200,
  "ssoSessionMaxLifespan": 86400,
  "offlineSessionIdleTimeout": 2592000,
  "clients": [
    {
      "clientId": "swagger-ui",
      "name": "Swagger UI",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:8080/api-docs/swagger-ui/oauth2-redirect.html"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@tekmetric.com",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-tekmetric"
      ]
    },
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@tekmetric.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "user123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-tekmetric"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "default-roles-tekmetric",
        "description": "Default roles for tekmetric realm",
        "composite": true,
        "composites": {
          "client": {
            "account": [
              "view-profile",
              "manage-account"
            ]
          }
        }
      },
      {
        "name": "admin",
        "description": "Administrator role"
      },
      {
        "name": "user",
        "description": "Standard user role"
      }
    ]
  },
  "scopeMappings": [],
  "clientScopeMappings": {}
}

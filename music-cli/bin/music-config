#!/usr/bin/env bash
#
# music-config - Manage Music Library CLI configuration
#
# Usage:
#   music-config [action] [options]
#

set -euo pipefail

# Detect script and repository root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Source required libraries
source "$REPO_ROOT/lib/colors.sh"
source "$REPO_ROOT/lib/common.sh"
source "$REPO_ROOT/lib/validate.sh"

# Initialize
init_common
check_dependencies

# Define user config file path
USER_CONFIG_FILE="${HOME}/.music-cli/config"

# Show usage information
function show_help() {
    cat << EOF
Usage: music-config [action] [options]

Manage configuration settings for the Music Library CLI.

ACTIONS:
    show                Show current configuration (default)
    set <key> <value>   Set a configuration value
    unset <key>         Remove a configuration value
    reset               Reset all configuration to defaults
    path                Show configuration file path

CONFIGURATION KEYS:
    api.url             API base URL (default: http://localhost:8080)
    output.format       Output format: formatted or json (default: formatted)
    page.size           Default page size for lists (default: 20)

GLOBAL OPTIONS:
    --help              Show this help message

EXAMPLES:
    # Show current configuration
    music-config show

    # Set API URL
    music-config set api.url http://api.example.com:9090

    # Set output format to JSON
    music-config set output.format json

    # Set default page size
    music-config set page.size 50

    # Remove a configuration value
    music-config unset api.url

    # Reset all configuration
    music-config reset

    # Show configuration file path
    music-config path

EOF
}

# Show current configuration
function action_show() {
    # Load config to get current values
    load_config

    echo "$(color_bold "Music Library CLI Configuration")"
    echo ""
    echo "Configuration file: $USER_CONFIG_FILE"
    if [[ -f "$USER_CONFIG_FILE" ]]; then
        echo "Status: $(color_success "exists")"
    else
        echo "Status: not created (using defaults)"
    fi
    echo ""
    echo "$(color_bold "Current Settings:")"
    echo ""
    printf "  %-20s %s\n" "api.url" "$API_URL"
    printf "  %-20s %s\n" "output.format" "$OUTPUT_FORMAT"
    printf "  %-20s %s\n" "page.size" "$PAGE_SIZE"
    echo ""
    echo "$(color_bold "Configuration Precedence:")"
    echo "  1. Command-line options (highest)"
    echo "  2. Environment variables (MUSIC_API_URL, MUSIC_OUTPUT_FORMAT)"
    echo "  3. User config file (~/.music-cli/config)"
    echo "  4. Repository config (music-cli/config/config.sh)"
    echo "  5. Built-in defaults (lowest)"
}

# Set a configuration value
function action_set() {
    local key="$1"
    local value="$2"

    # Validate key
    case "$key" in
        api.url)
            if ! validate_url "$value"; then
                log_error "Invalid URL: $value"
                exit $EXIT_USAGE
            fi
            ;;
        output.format)
            if ! validate_output_format "$value"; then
                log_error "Invalid output format: $value (must be 'formatted' or 'json')"
                exit $EXIT_USAGE
            fi
            ;;
        page.size)
            if ! validate_positive_integer "$value"; then
                log_error "Invalid page size: $value (must be a positive integer)"
                exit $EXIT_USAGE
            fi
            ;;
        *)
            log_error "Unknown configuration key: $key"
            echo ""
            echo "Valid keys: api.url, output.format, page.size"
            exit $EXIT_USAGE
            ;;
    esac

    # Create config directory if it doesn't exist
    local config_dir
    config_dir=$(dirname "$USER_CONFIG_FILE")
    if [[ ! -d "$config_dir" ]]; then
        mkdir -p "$config_dir"
    fi

    # Read existing config or create new
    local temp_file="${USER_CONFIG_FILE}.tmp"
    local key_found=false

    if [[ -f "$USER_CONFIG_FILE" ]]; then
        # Update existing key or add new one
        while IFS= read -r line || [[ -n "$line" ]]; do
            # Check if this line sets our key
            if [[ "$line" =~ ^[[:space:]]*MUSIC_.*=.* ]]; then
                local line_key
                case "$key" in
                    api.url)
                        line_key="MUSIC_API_URL"
                        ;;
                    output.format)
                        line_key="MUSIC_OUTPUT_FORMAT"
                        ;;
                    page.size)
                        line_key="MUSIC_PAGE_SIZE"
                        ;;
                esac

                if [[ "$line" =~ ^[[:space:]]*${line_key}= ]]; then
                    echo "${line_key}=\"${value}\"" >> "$temp_file"
                    key_found=true
                else
                    echo "$line" >> "$temp_file"
                fi
            else
                echo "$line" >> "$temp_file"
            fi
        done < "$USER_CONFIG_FILE"

        # If key wasn't found, append it
        if [[ "$key_found" == "false" ]]; then
            case "$key" in
                api.url)
                    echo "MUSIC_API_URL=\"${value}\"" >> "$temp_file"
                    ;;
                output.format)
                    echo "MUSIC_OUTPUT_FORMAT=\"${value}\"" >> "$temp_file"
                    ;;
                page.size)
                    echo "MUSIC_PAGE_SIZE=\"${value}\"" >> "$temp_file"
                    ;;
            esac
        fi

        mv "$temp_file" "$USER_CONFIG_FILE"
    else
        # Create new config file
        cat > "$USER_CONFIG_FILE" << EOF
#!/usr/bin/env bash
#
# Music Library CLI User Configuration
#
# This file is sourced by the CLI tools to set default configuration.
# You can also override these settings with environment variables or command-line options.
#

EOF
        case "$key" in
            api.url)
                echo "MUSIC_API_URL=\"${value}\"" >> "$USER_CONFIG_FILE"
                ;;
            output.format)
                echo "MUSIC_OUTPUT_FORMAT=\"${value}\"" >> "$USER_CONFIG_FILE"
                ;;
            page.size)
                echo "MUSIC_PAGE_SIZE=\"${value}\"" >> "$USER_CONFIG_FILE"
                ;;
        esac
    fi

    log_success "Configuration updated: $key = $value"
    echo ""
    echo "The new value will be used for future commands."
}

# Unset a configuration value
function action_unset() {
    local key="$1"

    # Validate key
    case "$key" in
        api.url|output.format|page.size)
            ;;
        *)
            log_error "Unknown configuration key: $key"
            echo ""
            echo "Valid keys: api.url, output.format, page.size"
            exit $EXIT_USAGE
            ;;
    esac

    if [[ ! -f "$USER_CONFIG_FILE" ]]; then
        log_warning "Configuration file does not exist: $USER_CONFIG_FILE"
        echo "Nothing to unset."
        exit 0
    fi

    # Remove the key from config
    local temp_file="${USER_CONFIG_FILE}.tmp"
    local line_key

    case "$key" in
        api.url)
            line_key="MUSIC_API_URL"
            ;;
        output.format)
            line_key="MUSIC_OUTPUT_FORMAT"
            ;;
        page.size)
            line_key="MUSIC_PAGE_SIZE"
            ;;
    esac

    # Filter out the line with this key
    grep -v "^[[:space:]]*${line_key}=" "$USER_CONFIG_FILE" > "$temp_file" || true
    mv "$temp_file" "$USER_CONFIG_FILE"

    log_success "Configuration removed: $key"
    echo ""
    echo "The default value will be used for future commands."
}

# Reset configuration to defaults
function action_reset() {
    if [[ ! -f "$USER_CONFIG_FILE" ]]; then
        echo "Configuration file does not exist. Nothing to reset."
        exit 0
    fi

    # Ask for confirmation
    echo ""
    log_warning "This will delete your configuration file: $USER_CONFIG_FILE"
    echo ""
    read -p "Are you sure you want to reset all configuration? (y/N) " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Reset cancelled."
        exit 0
    fi

    rm "$USER_CONFIG_FILE"
    log_success "Configuration reset to defaults"
}

# Show configuration file path
function action_path() {
    echo "$USER_CONFIG_FILE"

    if [[ -f "$USER_CONFIG_FILE" ]]; then
        echo "(file exists)"
    else
        echo "(file does not exist)"
    fi
}

# Main script logic
ACTION="${1:-show}"

case "$ACTION" in
    --help|-h)
        show_help
        exit 0
        ;;
    show)
        action_show
        ;;
    set)
        if [[ $# -lt 3 ]]; then
            log_error "Missing arguments for 'set' action"
            echo ""
            echo "Usage: music-config set <key> <value>"
            exit $EXIT_USAGE
        fi
        action_set "$2" "$3"
        ;;
    unset)
        if [[ $# -lt 2 ]]; then
            log_error "Missing key for 'unset' action"
            echo ""
            echo "Usage: music-config unset <key>"
            exit $EXIT_USAGE
        fi
        action_unset "$2"
        ;;
    reset)
        action_reset
        ;;
    path)
        action_path
        ;;
    *)
        log_error "Unknown action: $ACTION"
        echo ""
        show_help
        exit $EXIT_USAGE
        ;;
esac

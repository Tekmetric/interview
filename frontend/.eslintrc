{
  "extends": ["airbnb", "airbnb-typescript"],
  "parserOptions": {
    "project": "./tsconfig.eslint.json"
  },
  "settings": {
    "import/resolver": {
      "node": {
        "extensions": [".js", ".jsx", ".ts", ".tsx"]
      }
    } 
  },
  "rules": {
    "max-len": ["error", { "code": 140 }],
    "import/no-extraneous-dependencies": ["off"]
  }
}
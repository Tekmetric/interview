				{
					"name": "Update Vehicle",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"brand\": \"Honda\",\n    \"model\": \"Civic\",\n    \"registrationYear\": 2023,\n    \"licensePlate\": \"XYZ-789\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/vehicles/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"vehicles",
								"1"
							]
						},
						"description": "Update an existing vehicle by ID. Requires CUSTOMER role. Only the vehicle owner can update their own vehicles. License plate must be unique. The owner is automatically set from the authenticated user's JWT token."
					},
					"response": []
				},
				{
					"name": "Delete Vehicle",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/vehicles/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"vehicles",
								"1"
							]
						},
						"description": "Delete a vehicle by ID. Requires CUSTOMER role. Only the vehicle owner can delete their own vehicles."
					},
					"response": []
				}
			],
			"description": "Endpoints for managing vehicles"
		},

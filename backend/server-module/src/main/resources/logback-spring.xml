<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">

    <!-- Optional: pick up Spring Boot log level config -->
    <springProperty scope="context" name="LOG_LEVEL_ROOT" source="logging.level.root" defaultValue="INFO"/>

    <!-- Console appender with JSON encoder -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Add static fields to every log -->
            <customFields>{"service":"vehicle-user-api","environment":"local"}</customFields>
        </encoder>
    </appender>

    <!-- Root logger -->
    <root level="${LOG_LEVEL_ROOT}">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>

    <!-- Reduce SQL noise if needed -->
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.hibernate.type.descriptor.sql" level="WARN"/>
    <logger name="org.springframework.jdbc.datasource.init" level="INFO"/>
</configuration>

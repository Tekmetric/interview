#!/usr/bin/env bash
#
# Music Library API Demo - CLI Version
#
# This script demonstrates all features of the Music Library API
# using the music-cli command-line tools.
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Configuration
API_URL="${MUSIC_API_URL:-http://localhost:8080}"
CLI_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../music-cli/bin" && pwd)"
PAUSE_DURATION=3

# Function to print section headers
section() {
    echo ""
    echo -e "${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${MAGENTA}$1${NC}"
    echo -e "${MAGENTA}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# Function to print step headers
step() {
    echo ""
    echo -e "${CYAN}▶ Step $1: $2${NC}"
    echo ""
}

# Function to pause between steps
pause() {
    sleep $PAUSE_DURATION
}

# Function to execute CLI command
run_cli() {
    local cmd="$1"
    shift
    echo -e "${YELLOW}Command: $cmd $@${NC}"
    "$CLI_DIR/$cmd" "$@"
    echo ""
}

# Function to execute CLI command and capture JSON output
run_cli_json() {
    local cmd="$1"
    shift
    echo -e "${YELLOW}Command: $cmd $@${NC}" >&2
    "$CLI_DIR/$cmd" "$@"
}

# Variables to store IDs
PINK_FLOYD_ID=""
LED_ZEPPELIN_ID=""
ACDC_ID=""
SONG_IDS=()
ALBUM_IDS=()

# ============================================================================
# SECTION 1: Initial Setup
# ============================================================================

section "SECTION 1: Initial Setup"

step 1 "Display Welcome Message"
cat << 'EOF'
╔═══════════════════════════════════════════════════════════════╗
║                                                               ║
║        MUSIC LIBRARY API - COMPREHENSIVE DEMO (CLI)           ║
║                                                               ║
║  This demo will showcase all features of the Music Library   ║
║  API using the command-line interface.                        ║
║                                                               ║
╚═══════════════════════════════════════════════════════════════╝
EOF
pause

step 2 "Check API Connectivity"
run_cli music-config show
pause

step 3 "List Existing Artists (Starting State)"
run_cli music-artist list
pause

# ============================================================================
# SECTION 2: Artist Management
# ============================================================================

section "SECTION 2: Artist Management"

step 4 "Create Artist: Pink Floyd"
RESPONSE=$(run_cli music-artist --json create --name "Pink Floyd")
PINK_FLOYD_ID=$(echo "$RESPONSE" | jq -r '.id')
echo "Created Pink Floyd with ID: $PINK_FLOYD_ID"
pause

step 5 "Create Artist: Led Zeppelin"
RESPONSE=$(run_cli music-artist --json create --name "Led Zeppelin")
LED_ZEPPELIN_ID=$(echo "$RESPONSE" | jq -r '.id')
echo "Created Led Zeppelin with ID: $LED_ZEPPELIN_ID"
pause

step 6 "Create Artist: AC/DC"
RESPONSE=$(run_cli music-artist --json create --name "AC/DC")
ACDC_ID=$(echo "$RESPONSE" | jq -r '.id')
echo "Created AC/DC with ID: $ACDC_ID"
pause

step 7 "List All Artists"
run_cli music-artist list --size 10
pause

step 8 "Get Details for Pink Floyd"
run_cli music-artist get "$PINK_FLOYD_ID"
pause

step 9 "Update Pink Floyd's Name"
run_cli music-artist update "$PINK_FLOYD_ID" --name "Pink Floyd (Remastered)"
pause

step 10 "List Artists Again (Verify Update)"
run_cli music-artist list --size 10
pause

# ============================================================================
# SECTION 3: Song Management
# ============================================================================

section "SECTION 3: Song Management"

step 11 "Create Song: Comfortably Numb by Pink Floyd"
RESPONSE=$(run_cli music-song --json create \
    --title "Comfortably Numb" \
    --length 382 \
    --release-date 1979-11-30 \
    --artist-id "$PINK_FLOYD_ID")
SONG_IDS[0]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created song with ID: ${SONG_IDS[0]}"
pause

step 12 "Create Song: Wish You Were Here by Pink Floyd"
RESPONSE=$(run_cli music-song --json create \
    --title "Wish You Were Here" \
    --length 334 \
    --release-date 1975-09-12 \
    --artist-id "$PINK_FLOYD_ID")
SONG_IDS[1]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created song with ID: ${SONG_IDS[1]}"
pause

step 13 "Create Song: Shine On You Crazy Diamond by Pink Floyd"
RESPONSE=$(run_cli music-song --json create \
    --title "Shine On You Crazy Diamond" \
    --length 810 \
    --release-date 1975-09-12 \
    --artist-id "$PINK_FLOYD_ID")
SONG_IDS[2]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created song with ID: ${SONG_IDS[2]}"
pause

step 14 "Create Song: Stairway to Heaven by Led Zeppelin"
RESPONSE=$(run_cli music-song --json create \
    --title "Stairway to Heaven" \
    --length 482 \
    --release-date 1971-11-08 \
    --artist-id "$LED_ZEPPELIN_ID")
SONG_IDS[3]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created song with ID: ${SONG_IDS[3]}"
pause

step 15 "Create Song: Kashmir by Led Zeppelin"
RESPONSE=$(run_cli music-song --json create \
    --title "Kashmir" \
    --length 515 \
    --release-date 1975-02-24 \
    --artist-id "$LED_ZEPPELIN_ID")
SONG_IDS[4]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created song with ID: ${SONG_IDS[4]}"
pause

step 16 "Create Song: Back in Black by AC/DC"
RESPONSE=$(run_cli music-song --json create \
    --title "Back in Black" \
    --length 255 \
    --release-date 1980-07-25 \
    --artist-id "$ACDC_ID")
SONG_IDS[5]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created song with ID: ${SONG_IDS[5]}"
pause

step 17 "List All Songs"
run_cli music-song list
pause

step 18 "Get Details for Comfortably Numb"
run_cli music-song get "${SONG_IDS[0]}"
pause

step 19 "Update Comfortably Numb Length to 384 Seconds"
run_cli music-song update "${SONG_IDS[0]}" --length 384
pause

step 20 "List Songs Filtered by Pink Floyd"
run_cli music-song list --artist "$PINK_FLOYD_ID"
pause

step 21 "List Songs Sorted by Release Date (Descending)"
run_cli music-song list --sort "releaseDate,desc"
pause

# ============================================================================
# SECTION 4: Album Management
# ============================================================================

section "SECTION 4: Album Management"

step 22 "Create Album: The Wall by Pink Floyd"
RESPONSE=$(run_cli music-album --json create \
    --title "The Wall" \
    --release-date 1979-11-30 \
    --artist-id "$PINK_FLOYD_ID" \
    --song-ids "${SONG_IDS[0]}")
ALBUM_IDS[0]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created album with ID: ${ALBUM_IDS[0]}"
pause

step 23 "Create Album: Wish You Were Here by Pink Floyd"
RESPONSE=$(run_cli music-album --json create \
    --title "Wish You Were Here" \
    --release-date 1975-09-12 \
    --artist-id "$PINK_FLOYD_ID" \
    --song-ids "${SONG_IDS[1]},${SONG_IDS[2]}")
ALBUM_IDS[1]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created album with ID: ${ALBUM_IDS[1]}"
pause

step 24 "Create Album: Led Zeppelin IV by Led Zeppelin"
RESPONSE=$(run_cli music-album --json create \
    --title "Led Zeppelin IV" \
    --release-date 1971-11-08 \
    --artist-id "$LED_ZEPPELIN_ID" \
    --song-ids "${SONG_IDS[3]}")
ALBUM_IDS[2]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created album with ID: ${ALBUM_IDS[2]}"
pause

step 25 "Create Album: Physical Graffiti by Led Zeppelin"
RESPONSE=$(run_cli music-album --json create \
    --title "Physical Graffiti" \
    --release-date 1975-02-24 \
    --artist-id "$LED_ZEPPELIN_ID" \
    --song-ids "${SONG_IDS[4]}")
ALBUM_IDS[3]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created album with ID: ${ALBUM_IDS[3]}"
pause

step 26 "Create Album: Back in Black by AC/DC"
RESPONSE=$(run_cli music-album --json create \
    --title "Back in Black" \
    --release-date 1980-07-25 \
    --artist-id "$ACDC_ID" \
    --song-ids "${SONG_IDS[5]}")
ALBUM_IDS[4]=$(echo "$RESPONSE" | jq -r '.id')
echo "Created album with ID: ${ALBUM_IDS[4]}"
pause

step 27 "List All Albums"
run_cli music-album list
pause

step 28 "Get Details for The Wall Album (with songs)"
run_cli music-album get "${ALBUM_IDS[0]}" --with-songs
pause

step 29 "Update The Wall Album Title"
run_cli music-album update "${ALBUM_IDS[0]}" --title "The Wall (Remastered)"
pause

step 30 "List Albums Filtered by Pink Floyd"
run_cli music-album list --artist "$PINK_FLOYD_ID"
pause

step 31 "Get Pink Floyd with Albums"
run_cli music-artist get "$PINK_FLOYD_ID" --with-albums
pause

step 32 "Get Pink Floyd with Songs"
run_cli music-artist get "$PINK_FLOYD_ID" --with-songs
pause

# ============================================================================
# SECTION 5: Search Functionality
# ============================================================================

section "SECTION 5: Search Functionality"

step 33 "Search Across All Entities for 'Floyd'"
run_cli music-search "Floyd"
pause

step 34 "Search for 'heaven'"
run_cli music-search "heaven"
pause

step 35 "Search for 'black'"
run_cli music-search "black"
pause

step 36 "Search for 'led' (Artists Only)"
run_cli music-search "led" --type artist
pause

step 37 "Search for 'wish' (Songs Only)"
run_cli music-search "wish" --type song
pause

step 38 "Search for 'back' (Albums Only)"
run_cli music-search "back" --type album
pause

# ============================================================================
# SECTION 6: Pagination and Sorting
# ============================================================================

section "SECTION 6: Pagination and Sorting"

step 39 "List Songs with Page Size 2 (First Page)"
run_cli music-song list --page 0 --size 2
pause

step 40 "List Songs with Page Size 2 (Second Page)"
run_cli music-song list --page 1 --size 2
pause

step 41 "List Albums Sorted by Release Date (Ascending)"
run_cli music-album list --sort "releaseDate,asc"
pause

step 42 "List Albums Sorted by Release Date (Descending)"
run_cli music-album list --sort "releaseDate,desc"
pause

# ============================================================================
# SECTION 7: Deletion and Cleanup
# ============================================================================

section "SECTION 7: Deletion and Cleanup"

step 43 "Delete Song: Kashmir"
run_cli music-song delete "${SONG_IDS[4]}" --force
pause

step 44 "Delete Album: Physical Graffiti"
run_cli music-album delete "${ALBUM_IDS[3]}" --force
pause

step 45 "List Remaining Albums"
run_cli music-album list
pause

# ============================================================================
# SECTION 8: Final State
# ============================================================================

section "SECTION 8: Final State"

step 46 "Display Final Statistics"
echo "Fetching final statistics..."
ARTIST_RESPONSE=$(run_cli music-artist --json list --size 1000)
SONG_RESPONSE=$(run_cli music-song --json list --size 1000)
ALBUM_RESPONSE=$(run_cli music-album --json list --size 1000)

TOTAL_ARTISTS=$(echo "$ARTIST_RESPONSE" | jq -r '.totalElements')
TOTAL_SONGS=$(echo "$SONG_RESPONSE" | jq -r '.totalElements')
TOTAL_ALBUMS=$(echo "$ALBUM_RESPONSE" | jq -r '.totalElements')

cat << EOF

╔════════════════════════════════════════╗
║      FINAL LIBRARY STATISTICS          ║
╠════════════════════════════════════════╣
║  Total Artists:  $TOTAL_ARTISTS                      ║
║  Total Songs:    $TOTAL_SONGS                      ║
║  Total Albums:   $TOTAL_ALBUMS                      ║
╚════════════════════════════════════════╝

EOF
pause

step 47 "List All Artists with Content"
run_cli music-artist list
pause

step 48 "Display Success Message"
cat << 'EOF'

╔═══════════════════════════════════════════════════════════════╗
║                                                               ║
║                    DEMO COMPLETED SUCCESSFULLY!               ║
║                                                               ║
║  Summary of Operations:                                       ║
║  ✓ Created 3 artists                                          ║
║  ✓ Created 6 songs                                            ║
║  ✓ Created 5 albums                                           ║
║  ✓ Updated 1 artist, 1 song, 1 album                          ║
║  ✓ Deleted 1 song, 1 album                                    ║
║  ✓ Demonstrated search, filtering, pagination, sorting        ║
║                                                               ║
║  The Music Library API is fully functional!                   ║
║                                                               ║
╚═══════════════════════════════════════════════════════════════╝

EOF

echo -e "${GREEN}All CLI commands executed successfully!${NC}"
echo ""

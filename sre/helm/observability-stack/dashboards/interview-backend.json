      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 13,
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"interview-backend\",container=\"interview-backend\"}[$__rate_interval])) by (pod)",
          "legendFormat": "{{pod}}",

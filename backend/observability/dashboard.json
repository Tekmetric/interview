                "matcher": {
                  "id": "byRegexp",
                  "options": "5.."
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "red"
                    }
                  }
                ]
              }
            ]
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "right"
            }
          },
          "targets": [
            {
              "expr": "sum by (status) (rate(http_server_requests_milliseconds_count[5m]))",
              "legendFormat": "{{status}}"
            }
          ]
        }
      ]

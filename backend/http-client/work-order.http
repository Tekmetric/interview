{
  "name": "Oil Filter",
  "quantity": 1,
  "partNumber": "00000000-0000-0000-0000-000000000099"
}

> {%
    client.global.set("partLineItemId", response.body.id);
%}

###
DELETE {{host}}/work-orders/{{workOrderId}}/part-line-items/{{partLineItemId}}
#X-XSRF-TOKEN: {{xsrf_token}}

###

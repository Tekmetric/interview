{
  "id": null,
  "uid": "interview-app-overview",
  "title": "Interview App \u2014 Overview",
  "tags": [
    "interview-app",
    "spring-boot"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "title": "\ud83d\udfe2 Uptime",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "process_uptime_milliseconds / 1000",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "title": "\ud83d\udd10 Login Success",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "targets": [
        {
          "expr": "auth_login_total{outcome=\"success\"}",
          "legendFormat": "logins"
        }
      ]
    },
    {
      "title": "\ud83d\udd12 Login Failures",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",

{
  "name": "automation-exercise-qa",
  "version": "1.0.0",
  "description": "Playwright Automation Framework for Automation Exercise",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test tests/ui/",
    "test:api": "npx playwright test tests/api/",
    "test:integration": "npx playwright test tests/integration/",
    "test:headed": "npx playwright test --headed",
    "report": "npx playwright show-report",
    "install-browsers": "npx playwright install"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0"
  }
}

								"{{baseUrl}}"
							],
							"path": [
								"api",
								"vehicles",
								"1"
							]
						},
						"description": "Retrieve a specific vehicle by its ID. Requires ADMIN or CUSTOMER role. Customers can only access their own vehicles."
					},
					"response": []
				},
